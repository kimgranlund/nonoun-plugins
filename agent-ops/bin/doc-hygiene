#!/usr/bin/env python3
"""doc-hygiene — advisory canonical-doc hygiene lint for agent-ops (repo-ops's patterns, mechanized).

Flags, at write time, the structural smells `repo-ops` audits for on the canonical doc surface:

  UNDATED        a canonical / memory doc with no `date:` frontmatter and no `_Last reviewed:_` line
                 (invisible to staleness detection)
  ENTRY-BLOAT    AGENTS.md / CLAUDE.md over the ~200-line entry-file ceiling (Anthropic); warns from 150
  DRIFT-RISK     a substantial CLAUDE.md that is NOT a thin pointer to AGENTS.md (a divergent second copy)
  NO-FRONTMATTER a doc under a memory dir (.agents/brain/ , docs/{adrs,postmortems,runbooks,decisions}/) with
                 no YAML frontmatter at all

ADVISORY ONLY. `--hook` mode ALWAYS exits 0 — it never blocks a write; it prints suggestions to stderr.
Direct mode exits 1 when smells are found (for ad-hoc use / CI-as-warning).

Usage:
  doc-hygiene <file.md> ...     # lint files; exit 1 if any smell, 0 if clean
  doc-hygiene --hook            # PostToolUse hook: reads the tool payload on stdin; advisory; exit 0
  doc-hygiene selftest
Stdlib only (Python 3.8+).
"""
import json
import os
import re
import sys

CANON = re.compile(r"(^|/)(README|CHANGELOG|ROADMAP|PLAN|BACKLOG|ARCHITECTURE|CONTRIBUTING|SECURITY)\.md$", re.I)
ENTRY = re.compile(r"(^|/)(AGENTS|CLAUDE)\.md$")
MEMORY = re.compile(r"(^|/)(\.agents/brain|docs)/(adrs|postmortems|runbooks|decisions)/", re.I)
DATEISH = re.compile(r"(?mi)^\s*date\s*:|_Last reviewed:")


def _dated(text):
    return bool(DATEISH.search(text[:1500]))


def lint(path, text):
    """Return a list of (code, message) advisory smells for one doc."""
    smells = []
    base = path.replace(os.sep, "/")
    lines = text.count("\n") + (0 if text.endswith("\n") or not text else 1)
    if ENTRY.search(base):
        if lines > 200:
            smells.append(("ENTRY-BLOAT", f"{lines} lines — over the ~200-line entry-file ceiling; move detail into linked subfolders"))
        elif lines > 150:
            smells.append(("ENTRY-BLOAT", f"{lines} lines — approaching the ~200-line ceiling (warn at 150)"))
        if base.endswith("CLAUDE.md") and lines > 25 and "AGENTS.md" not in text:
            smells.append(("DRIFT-RISK", "a substantial CLAUDE.md that doesn't point at AGENTS.md — make it a thin pointer, or `ln -s AGENTS.md CLAUDE.md`"))
    if (CANON.search(base) or MEMORY.search(base)) and not _dated(text):
        smells.append(("UNDATED", "no `date:` frontmatter or `_Last reviewed:_` line — invisible to staleness detection"))
    if MEMORY.search(base) and not text.startswith("---"):
        smells.append(("NO-FRONTMATTER", "a memory doc with no YAML frontmatter — add date/status so the audit can see it"))
    return smells


def _report(path, smells, stream):
    if not smells:
        return
    print(f"doc-hygiene: {path}", file=stream)
    for code, msg in smells:
        print(f"  [{code}] {msg}", file=stream)


def _selftest():
    import tempfile
    ok = True
    cases = {
        "AGENTS.md": ("x\n" * 210, "ENTRY-BLOAT"),
        "CLAUDE.md": ("# rules\n" + "detail line\n" * 30, "DRIFT-RISK"),
        "README.md": ("# Title\n\nNo date here.\n", "UNDATED"),
        os.path.join(".agents/brain", "adrs", "0001-x.md"): ("# ADR\n\nbody\n", "NO-FRONTMATTER"),
        os.path.join("docs", "guide.md"): ("---\ndate: 2026-06-03\n---\n# ok\n", None),
    }
    with tempfile.TemporaryDirectory() as d:
        for rel, (content, expect) in cases.items():
            p = os.path.join(d, rel)
            os.makedirs(os.path.dirname(p) or d, exist_ok=True)
            open(p, "w").write(content)
            codes = {c for c, _ in lint(p, content)}
            if expect and expect not in codes:
                ok = False
                print(f"selftest: {rel} missing {expect} (got {codes})", file=sys.stderr)
            if expect is None and codes:
                ok = False
                print(f"selftest: {rel} false-flagged {codes}", file=sys.stderr)
    print("selftest: PASS" if ok else "selftest: FAIL")
    return 0 if ok else 1


def main(argv):
    if argv and argv[0] == "selftest":
        return _selftest()
    if argv and argv[0] == "--hook":
        try:  # PostToolUse payload on stdin; advisory — any failure is swallowed and we still exit 0
            payload = json.load(sys.stdin)
            ti = payload.get("tool_input", {}) or {}
            path = ti.get("file_path") or ti.get("path") or ""
            if path.endswith((".md", ".markdown")) and os.path.isfile(path):
                _report(path, lint(path, open(path, encoding="utf-8", errors="replace").read()), sys.stderr)
        except Exception:
            pass
        return 0  # ADVISORY — never blocks a write
    files = [a for a in argv if not a.startswith("-")]
    if not files:
        print("usage: doc-hygiene <file.md> ... | --hook | selftest", file=sys.stderr)
        return 2
    any_smell = False
    for f in files:
        if not os.path.isfile(f):
            continue
        smells = lint(f, open(f, encoding="utf-8", errors="replace").read())
        _report(f, smells, sys.stdout)
        any_smell = any_smell or bool(smells)
    return 1 if any_smell else 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
