node_modules/
.DS_Store
*.log

# Personal Claude Code settings (shared .claude/ content stays tracked)
.claude/settings.local.json

# Private name-decode maps for obscured critics/evals — never commit.
.name-map.md

# Ephemeral .agents/ test instances written cwd-relative by selftests/demos (harness-forge + dev-factory
# scaffold a lattice under .agents/<plugin>/ when run with that cwd). The REAL eval fixtures live under
# */evals/.../fixtures/.agents/ and stay tracked — these anchored rules deliberately do NOT match them.
/.agents/
/harness-forge/.agents/
/dev-factory/.agents/
/dev-factory/dev-server/.agents/

# Operator launch config for dev-server/run.sh — the filled-in env holds the operator's instance path +
# run policy (NOT plugin config); only the committed *.example template ships. run.sh also reads <instance>/run.env.
/dev-factory/dev-server/dev-factory.env
/dev-factory/dev-server/run.env
