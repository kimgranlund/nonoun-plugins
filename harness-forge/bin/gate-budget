#!/usr/bin/env python3
"""gate-budget — the wired STOP-gate: deny worker writes when the run is over budget (global) or the cell is blocked (per-cell).

`gate-*` blocks (naming-conventions.md, Tier 3). This is the mechanical floor under the autonomous loop, on
two axes — and BOTH are computed in code, not trusted to the orchestrator's prose (the council's convergent
v0.4.0 Critical: a loop's caps routed to inference is the routing law violated at the point of max blast radius):

  GLOBAL — once the run budget is EXHAUSTED (`lattice.run_budget_exhausted`: an absolute wall-clock deadline,
  or ledger-counted iterations/cells past the cap), this denies EVERY worker write. The orchestrator literally
  cannot write past its budget, whatever it believes its counter says.

  ARMING GAP (I-9) — an autonomous loop MARKED active (`/harness-run` sets the marker at step 0a) but with NO
  budget armed (the orchestrator skipped step 0b) is denied every write — fail-CLOSED rather than silently
  unbounded. The marker is what distinguishes the running loop from a human editing: attended single-cell work
  (`/harness-advance`) and manual edits never set it, so they stay free.

  PER-CELL — when a cell is `blocked` (the no-progress circuit breaker flipped it), a write to that cell's
  `asset_ref` is denied, so the worker can't grind a stuck cell.

A PreToolUse(Write|Edit) hook; exit 2 = deny. The orchestrator (`harness-builder`) starts the run budget
(`run-budget.py start`) and detects/blocks stuck cells between passes; the ENFORCEMENT of both bounds is here.

Like `gate-signal` it fails OPEN on anything it can't parse (a malformed event, no lattice/budget, an unmapped
path → exit 0): a stop-gate that bricked every write on a parse hiccup would be worse than the runaway it
guards. It denies on exactly two conditions — an exhausted run budget (any write) or a write to a blocked
cell — and allows everything else.

Wired by `bin/wire.py` into the project's own loop (alongside gate-signal/emit-ledger/propagate-staleness),
reading the copied `_lattice.py`. Resolves the harness at `$HARNESS_DIR`, else `./.agents/harness`.

Usage:
  gate-budget --hook        # reads PreToolUse JSON on stdin; exit 2 (+reason) = DENY a write to a blocked cell
  gate-budget check <path>  # exit 2 if <path> is a blocked cell's asset (scripting/testing)
  gate-budget selftest
Stdlib only; Python 3.8+.
"""
import json
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
try:
    import lattice as _lat                  # plugin layout: bin/lattice.py is a sibling
except ImportError:                          # wired layout: .agents/harness/hooks/_lattice.py (private byte-copy)
    import _lattice as _lat


def _harness_dir():
    return os.environ.get("HARNESS_DIR") or ".agents/harness"


def _norm(p):
    p = (p or "").replace("\\", "/")
    return p[2:] if p.startswith("./") else p


def blocked_cell_for(path, d=None):
    """Return the (cell_id, reason) of a BLOCKED cell whose asset_ref matches `path`, else (None, None)."""
    d = d or _harness_dir()
    if not path or not os.path.isfile(os.path.join(d, "lattice.json")):
        return None, None
    try:
        lat = _lat.load(d)
    except (OSError, ValueError):
        return None, None
    p = _norm(path)
    for c in lat.get("cells", []):
        ref = c.get("asset_ref")
        if c.get("blocked") and ref and (p == _norm(ref) or p.endswith("/" + _norm(ref))):
            return _lat.cid(c), (c.get("blocked_reason") or "budget/no-progress stop")
    return None, None


def run_exhausted(d=None):
    """(exhausted, reason) for the active run budget — the GLOBAL ceiling, computed in the kernel from code."""
    import datetime
    d = d or _harness_dir()
    try:
        ex, why, _ = _lat.run_budget_exhausted(d, datetime.datetime.now().astimezone().isoformat(timespec="seconds"))
        return ex, why
    except Exception:                                     # noqa: BLE001 — a budget read error must fail open
        return False, None


def _hook():
    try:
        data = json.load(sys.stdin)
        ti = data.get("tool_input") or data.get("toolInput") or {}
        path = ti.get("file_path") or ti.get("path") or ti.get("file")
    except Exception:
        return 0                                          # fail open on a parse error — never brick the loop
    # GLOBAL bound first: once the run's budget is spent, deny EVERY worker write — the hard ceiling the
    # orchestrator cannot exceed (the council's convergent Critical: the global caps must be code, not prose).
    ex, why = run_exhausted()
    if ex:
        _ledger_deny(path, f"run-budget exhausted: {why}")
        sys.stderr.write(f"gate-budget: DENY — the run budget is EXHAUSTED ({why}). The bounded loop has reached its "
                         f"global cap; stop and hand back. Start a fresh run (`run-budget.py start …`) deliberately, "
                         f"not automatically.\n")
        return 2
    # ARMING GAP (I-9): an autonomous loop MARKED active but with NO budget armed is denied every write — fail-CLOSED
    # rather than silently unbounded. Two hardening fixes (0.5.3):
    #   (a) STALE WIRED KERNEL (David F.): if the wired `_lattice.py` predates I-9 (no `loop_unbudgeted`), this gate
    #       cannot provide the protection — DENY (fail closed) and tell the operator to re-wire, instead of silently
    #       re-opening the gap via the catch-all below.
    #   (b) STALE MARKER (Charity M.): a marker older than LOOP_TTL_S is a crashed-run corpse, not a live loop, so it
    #       must NOT wedge the project — `loop_unbudgeted(d, now)` returns False for it (the gate allows; status/stop
    #       surface it). The arming gap is still enforced for a *live* forgotten-start (caught within the TTL).
    import datetime
    now = datetime.datetime.now().astimezone().isoformat(timespec="seconds")
    if not hasattr(_lat, "loop_unbudgeted"):
        _ledger_deny(path, "stale wired kernel: _lattice.py predates the I-9 arming-gap protection")
        sys.stderr.write("gate-budget: DENY — the wired kernel copy (`_lattice.py`) is STALE: it lacks the I-9 "
                         "arming-gap protection this gate relies on, so it can't be trusted to bound the loop. "
                         "Re-wire to refresh it: `wire.py apply` then `wire.py check`. Refusing writes rather than "
                         "silently running un-protected.\n")
        return 2
    try:
        unb, detail = _lat.loop_unbudgeted(_harness_dir(), now)
    except Exception:                                     # noqa: BLE001 — a marker READ error (a hiccup, not a skew) fails open
        unb, detail = False, None
    if unb:
        _ledger_deny(path, f"arming gap: {detail}")
        ttl_min = getattr(_lat, "LOOP_TTL_S", 900) // 60
        sys.stderr.write(f"gate-budget: DENY — a loop is MARKED ACTIVE but no run budget is armed ({detail}). "
                         f"If a /harness-run loop is starting, arm a ceiling: `run-budget.py start --max-cells N "
                         f"--max-iterations M`. If NO loop is running (a crashed run left the marker), clear it: "
                         f"`run-budget.py stop` (a stale marker self-expires after ~{ttl_min} min).\n")
        return 2
    # PER-CELL bound: a blocked cell's asset is deny-on-write (the no-progress circuit breaker).
    cell_id, reason = blocked_cell_for(path)
    if cell_id:
        _ledger_deny(path, f"blocked cell {cell_id}: {reason}")
        sys.stderr.write(f"gate-budget: DENY — `{cell_id}` is BLOCKED ({reason}). The loop hit a no-progress "
                         f"signature on this cell; stop and surface it to the compass, do not keep grinding. "
                         f"Unblock it deliberately (`lattice.py unblock {cell_id}`) only after changing the approach.\n")
        return 2                                          # non-zero = deny the write
    return 0


def _ledger_deny(path, why):
    """Record the deny so gate-fires are countable (Charity/CV2: the bounding mechanism must not be mute)."""
    import datetime
    d = _harness_dir()
    try:
        _lat._append_ledger_event(d, {"operation": "record", "actor": "hook:gate-budget", "result": "deny",
                                      "ts": datetime.datetime.now().astimezone().isoformat(timespec="seconds"),
                                      "path": (path or "").replace("\\", "/"), "rationale": why})
    except Exception:                                     # noqa: BLE001 — a logging failure must never change the gate verdict
        pass


def selftest():
    import tempfile
    fails = []
    def expect(cond, label):
        if not cond:
            fails.append(label)
    with tempfile.TemporaryDirectory() as root:
        d = os.path.join(root, ".agents/harness")
        _lat.scaffold(d)
        lat = _lat.seed_lattice("t")
        for c in lat["cells"]:
            if _lat.cid(c) == "spec.task.first-slice":
                c["asset_ref"] = ".agents/harness/spec/first-slice.md"
        _lat.save(d, lat)

        # not blocked → allowed
        cid_, _ = blocked_cell_for(".agents/harness/spec/first-slice.md", d=d)
        expect(cid_ is None, "an unblocked cell's asset was treated as blocked")

        # block it → its asset write is denied; an unrelated path stays allowed
        lat = _lat.load(d)
        _lat.set_blocked(lat, "spec.task.first-slice", True, reason="no-progress: 3 fails")
        _lat.save(d, lat)
        cid_, reason = blocked_cell_for(".agents/harness/spec/first-slice.md", d=d)
        expect(cid_ == "spec.task.first-slice" and "no-progress" in reason, f"blocked cell's asset not denied: {cid_}")
        expect(blocked_cell_for("src/unrelated.py", d=d)[0] is None, "an unrelated path was denied")
        expect(blocked_cell_for(".agents/harness/spec/first-slice.md", d=os.path.join(root, "nowhere"))[0] is None,
               "missing harness did not fail open")

        # unblock → allowed again
        lat = _lat.load(d)
        _lat.set_blocked(lat, "spec.task.first-slice", False)
        _lat.save(d, lat)
        expect(blocked_cell_for(".agents/harness/spec/first-slice.md", d=d)[0] is None, "unblocked cell still denied")

        # GLOBAL bound: an exhausted run budget denies EVERY write (computed from code, no agent counter)
        import datetime
        now = datetime.datetime.now().astimezone().isoformat(timespec="seconds")
        past = (datetime.datetime.now().astimezone() - datetime.timedelta(seconds=10)).isoformat(timespec="seconds")
        ex, _, _ = _lat.run_budget_exhausted(d, now)
        expect(not ex, "a project with no active run was treated as exhausted (would deny all writes)")
        _lat.run_budget_start(d, now, deadline_iso=past)          # a deadline already in the past = exhausted
        ex, why, _ = _lat.run_budget_exhausted(d, now)
        expect(ex and "wall-clock" in (why or ""), f"the global run budget was not exhausted by a past deadline: {why}")
        _lat.run_budget_clear(d)
        expect(not _lat.run_budget_exhausted(d, now)[0], "clearing the run did not lift the global deny")

        # ARMING GAP (I-9): a LIVE marked loop with no budget is denied; arming/clearing lifts it; unmarked never denied.
        expect(not _lat.loop_unbudgeted(d, now)[0], "an unmarked project was treated as an unbudgeted loop (would deny manual edits)")
        _lat.loop_marker_set(d, now, label="harness-run --max-cells 8")
        unb, detail = _lat.loop_unbudgeted(d, now)
        expect(unb and "no run budget" in (detail or ""), f"a live marked loop with no budget was not flagged unbudgeted: {detail}")
        # STALE MARKER (Charity C1 — the crash-wedge fix): a marker older than LOOP_TTL_S is a crashed-run corpse,
        # NOT a live loop, so it must NOT wedge the project — while a FRESH marker is still enforced.
        stale_now = (datetime.datetime.now().astimezone() + datetime.timedelta(seconds=_lat.LOOP_TTL_S + 60)).isoformat(timespec="seconds")
        expect(_lat.loop_marker_stale(d, stale_now), "a marker older than the TTL was not detected stale")
        expect(not _lat.loop_unbudgeted(d, stale_now)[0], "a STALE marked loop still wedged the project (no TTL backstop) — Charity C1")
        expect(_lat.loop_unbudgeted(d, now)[0], "a FRESH marked loop was wrongly treated as stale (TTL too tight)")
        _lat.run_budget_start(d, now, max_cells=8)                 # arm the ceiling → no longer the arming gap
        expect(not _lat.loop_unbudgeted(d, now)[0], "arming a budget did not lift the arming-gap deny")
        _lat.run_budget_clear(d)
        expect(_lat.loop_unbudgeted(d, now)[0], "clearing the budget while still (freshly) marked did not re-trip the arming gap")
        _lat.loop_marker_clear(d)                                  # end the loop → free again
        expect(not _lat.loop_unbudgeted(d, now)[0], "clearing the marker (stop) did not lift the arming-gap deny")
        # MARKER SCHEMA (Scott M1): a hand-corrupted marker is caught by loop_marker_check (typed like budget.json)
        os.makedirs(os.path.join(d, "run"), exist_ok=True)
        json.dump({"active": True, "started_ts": "not-a-date", "bogus": 1}, open(os.path.join(d, "run", "loop-active.json"), "w"))
        mc = _lat.loop_marker_check(d)
        expect(any("started_ts" in f for f in mc) and any("bogus" in f for f in mc), f"loop_marker_check missed a corrupt marker: {mc}")
        _lat.loop_marker_clear(d)
    if fails:
        sys.stderr.write("gate-budget selftest: FAIL\n")
        for f in fails:
            sys.stderr.write(f"  - {f}\n")
        return 1
    print("gate-budget selftest: OK (GLOBAL: an exhausted run budget denies every write, computed from code; "
          "ARMING GAP (I-9): a LIVE marked loop with no budget is denied, manual editing is not, and a STALE marker "
          "past the TTL does NOT wedge the project (the crash-fix); the marker is schema-checked; PER-CELL: a blocked "
          "cell's asset is denied, unrelated paths + unblocked cells allowed; fails open on no-harness — the wired "
          "circuit breaker that bounds even a runaway worker, on three axes)")
    return 0


def main(argv):
    if argv and argv[0] == "selftest":
        return selftest()
    if argv and argv[0] == "check" and len(argv) > 1:
        return 2 if blocked_cell_for(argv[1])[0] else 0
    if argv and argv[0] == "--hook":
        return _hook()
    print(__doc__.split("Usage:")[1].split("Stdlib")[0].strip(), file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
