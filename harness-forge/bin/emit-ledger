#!/usr/bin/env python3
"""emit-ledger — the FEEDBACK hook species: record engine-relevant writes into the append-only ledger.

`gate-*` blocks, `emit-*` injects, `propagate-*` cascades (naming-conventions.md, Tier 3). This is the
emit species for the USER's worker loop: a PostToolUse(Write|Edit) hook that appends an audit `record`
event to `ledger/events.jsonl` whenever a write touches the harness's state or a layer directory — the
tamper-evident audit trail the trust trajectory's unattended tiers require, kept mechanically rather than
by the worker remembering. It NEVER blocks (feedback is not a gate): always exit 0, including on
malformed input. The worker's own deliberate `ledger.py append` (with rationale + measured cost) remains
the engine's record of *why*; this hook is the raw *what happened* trail beneath it.

Feedback injection: when the audit invariant itself breaks (a harness exists but the event cannot be
recorded), the failure is surfaced to the model as `additionalContext` — a broken audit trail must be a
loud finding, not a silent gap.

Wired by `bin/wire.py` into the project's own `.claude/settings.json` (the plugin session ships only the
advisory `harness-hook`). Resolves the harness at `$HARNESS_DIR`, else `./.agents/harness` (hooks run with the
project as cwd).

Usage:
  emit-ledger --hook       # reads PostToolUse JSON on stdin; appends an audit event; ALWAYS exits 0
  emit-ledger selftest
Stdlib only; Python 3.8+.
"""
import datetime
import json
import os
import sys

LAYERS = ("ontology", "spec", "rubric", "policy", "capability", "methodology", "protocol", "ledger", "pattern")


def _harness_dir():
    return os.environ.get("HARNESS_DIR") or ".agents/harness"


def _relevant(path, d):
    """Is this write engine-relevant — harness state, or a layer-shaped asset directory?"""
    if not path:
        return False
    p = path.replace("\\", "/")
    dn = d.replace("\\", "/").rstrip("/")
    if p.startswith(dn + "/") or ("/" + dn + "/") in p:
        return True
    parts = [seg for seg in p.split("/") if seg not in (".", "")]
    return any(seg in LAYERS for seg in parts[:-1])


def record(path, d=None, tool="Write"):
    """Append the audit event. Returns (recorded: bool, context: str|None) — context only on a loud finding."""
    d = d or _harness_dir()
    if not os.path.isdir(d) or not _relevant(path, d):
        return False, None                            # no harness here / not engine-relevant → silently stand down
    event = {
        "operation": "record",
        "actor": "hook:emit-ledger",
        "ts": datetime.datetime.now().astimezone().isoformat(timespec="seconds"),
        "tool": tool,
        "path": path.replace("\\", "/"),
    }
    try:
        os.makedirs(os.path.join(d, "ledger"), exist_ok=True)
        with open(os.path.join(d, "ledger", "events.jsonl"), "a", encoding="utf-8") as f:
            f.write(json.dumps(event, separators=(",", ":")) + "\n")
        return True, None
    except OSError as e:                              # the audit invariant broke — surface it, never block
        return False, f"emit-ledger: could NOT record this write to the audit trail ({e}). The ledger is the loop's memory — fix the harness dir before trusting further passes."


def _hook():
    try:
        data = json.load(sys.stdin)
        ti = data.get("tool_input") or data.get("toolInput") or {}
        path = ti.get("file_path") or ti.get("path") or ti.get("file")
        tool = data.get("tool_name") or data.get("toolName") or "Write"
    except Exception:
        return 0                                      # malformed input → feedback never blocks
    _, ctx = record(path, tool=tool)
    if ctx:
        print(json.dumps({"hookSpecificOutput": {"hookEventName": "PostToolUse", "additionalContext": ctx}}))
    return 0


def selftest():
    import tempfile
    fails = []
    def expect(cond, label):
        if not cond:
            fails.append(label)
    with tempfile.TemporaryDirectory() as root:
        d = os.path.join(root, ".agents/harness")
        os.makedirs(os.path.join(d, "spec"))
        lp = os.path.join(d, "ledger", "events.jsonl")

        ok, ctx = record(".agents/harness/spec/first-slice.md", d=d)     # a layer write is recorded
        expect(ok and ctx is None, "engine-relevant write was not recorded")
        ok, _ = record("src/spec/parser.md", d=d)                  # any layer-shaped dir counts
        expect(ok, "layer-shaped asset dir write was not recorded")
        ok, ctx = record("src/main.py", d=d)                       # plain source is not engine-relevant
        expect(not ok and ctx is None, "irrelevant write was recorded (noise)")
        ok, ctx = record(None, d=d)
        expect(not ok and ctx is None, "empty path did not stand down")

        lines = open(lp, encoding="utf-8").read().strip().splitlines()
        expect(len(lines) == 2, f"expected 2 audit events, got {len(lines)}")
        e = json.loads(lines[0])
        expect(e["operation"] == "record" and e["actor"] == "hook:emit-ledger" and e["path"].endswith("first-slice.md"),
               f"audit event malformed: {e}")

        ok, ctx = record(".agents/harness/spec/x.md", d=os.path.join(root, "nowhere"))   # no harness → silent
        expect(not ok and ctx is None, "missing harness did not stand down silently")

        ro = os.path.join(root, "ro", ".agents/harness")                  # a harness whose ledger cannot be written → LOUD
        os.makedirs(os.path.join(ro, "ledger"))
        os.chmod(os.path.join(ro, "ledger"), 0o500)
        try:
            ok, ctx = record(".agents/harness/spec/y.md", d=ro)
            expect(not ok and ctx and "could NOT record" in ctx, "broken audit trail was not surfaced as a finding")
        finally:
            os.chmod(os.path.join(ro, "ledger"), 0o700)
    if fails:
        sys.stderr.write("emit-ledger selftest: FAIL\n")
        for f in fails:
            sys.stderr.write(f"  - {f}\n")
        return 1
    print("emit-ledger selftest: OK (records engine-relevant writes to the audit trail; silent on noise/no-harness; "
          "a broken trail is a loud finding; never blocks)")
    return 0


def main(argv):
    if argv and argv[0] == "selftest":
        return selftest()
    if argv and argv[0] == "--hook":
        return _hook()
    print(__doc__.split("Usage:")[1].split("Stdlib")[0].strip(), file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
