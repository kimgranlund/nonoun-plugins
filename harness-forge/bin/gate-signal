#!/usr/bin/env python3
"""gate-signal — the blocking protected-verifier gate, for the USER's worker loop (NOT the plugin session).

Published reward-hacking rates run to double-digit percentages of rollouts, a meaningful fraction
shipping deliberate exploit code (overwritten tests, monkey-patched scorers, deleted assertions). The
first and strongest defense is mechanical, not instructed: verifier assets — signal directories, rubric
files, eval suites, the naming/lattice schemas, and the hooks themselves — are DENY-ON-WRITE to worker
agents. Signals are written only by the validation path. The worker never grades its own homework,
structurally.

This is the gate species (it BLOCKS — unlike `harness-hook`, which only advises). It is meant to be
wired as a PreToolUse(Write|Edit) hook inside the user's autonomous WORKER loop — never into a shared
interactive session — where a non-zero exit denies the write. The protected set is configurable via
`HARNESS_PROTECTED` (newline- or comma-separated path globs); a sensible default ships.

Usage:
  gate-signal --hook          # reads PreToolUse JSON on stdin; exit 2 (+reason on stderr) = DENY a protected write
  gate-signal check <path>    # exit 1 if <path> is protected (for scripting/testing)
  gate-signal selftest
Stdlib only; Python 3.8+.
"""
import fnmatch
import json
import os
import sys

# Anchored at path-segment boundaries (a glob matches root-relative or after any `/`), NEVER on bare
# basenames — `docs/examples/lattice.json` and `src/hooks/useAuth.ts` are worker-writable; only the
# harness's own verifier assets are not. `.claude/settings.json` is protected so a worker cannot UNWIRE
# the gate (the wiring is itself a verifier asset); `.harness/ledger/*` so the append-only audit trail
# cannot be rewritten by a Write/Edit (the validation path and the hooks append via subprocess).
DEFAULT_PROTECTED = [
    ".harness/signals/*",
    ".harness/rubric/*",
    ".harness/hooks/*",
    ".harness/ledger/*",
    ".harness/run/*",          # the run budget IS the global bound's verifier asset — a worker that could rewrite
                               # budget.json (far-future deadline, null caps) would immortalize the run and lift the
                               # ceiling gate-budget enforces. Deny-on-write, like signals and the wiring. (council v0.4.1)
    ".harness/lattice.json",
    ".harness/*.schema.json",
    ".claude/settings.json",
    # NOTE: a bare `evals/*` was here — dropped (council/Simon). Wired into an arbitrary user project it would
    # deny writes to the user's OWN test directory, which is not a harness verifier asset. A project that keeps
    # its eval suite as a protected verifier asset opts in via HARNESS_PROTECTED.
]


def protected_globs():
    env = os.environ.get("HARNESS_PROTECTED")
    if env:
        return [g.strip() for g in env.replace(",", "\n").splitlines() if g.strip()]
    return DEFAULT_PROTECTED


def is_protected(path, globs=None):
    if not path:
        return False
    p = path.replace("\\", "/")
    if p.startswith("./"):
        p = p[2:]
    for g in (globs or protected_globs()):
        if fnmatch.fnmatch(p, g) or fnmatch.fnmatch(p, "*/" + g):
            return True
    return False


def selftest():
    fails = []
    def expect(cond, label):
        if not cond:
            fails.append(label)
    for p in (".harness/signals/spec.task.x/2026-06-12T09-00--pytest.json",
              ".harness/rubric/first-slice.md", ".harness/naming.schema.json",
              ".harness/hooks/gate-signal", ".harness/lattice.json",
              ".harness/ledger/events.jsonl",                       # the audit trail is tamper-evident
              ".harness/run/budget.json",                           # the global bound — a worker cannot lift its own ceiling
              ".claude/settings.json",                              # the wiring itself — a worker cannot unwire the gate
              "/abs/project/.harness/signals/x/y.json",             # absolute paths anchor at the segment boundary
              "sub/project/.claude/settings.json"):
        expect(is_protected(p), f"failed to protect a verifier asset: {p}")
    for p in (".harness/spec/first-slice.md", "src/main.py", "README.md",
              "docs/examples/lattice.json",                         # over-breadth regression: basename matching is gone
              "src/hooks/useAuth.ts",                               # a React hooks dir is not a verifier asset
              "schemas/foo.schema.json",                            # schemas outside .harness/ are the project's business
              "evals/suite.py", "tests/evals/run.py"):              # the user's OWN eval/test dir is not a harness asset (Simon)
        expect(not is_protected(p), f"wrongly protected a worker-writable path: {p}")
    # env override narrows/redefines the set (a project that DOES keep evals as verifier assets opts in)
    expect(is_protected("custom/secret.txt", ["custom/*"]), "explicit glob override did not protect")
    expect(is_protected("evals/suite.py", ["evals/*"]), "HARNESS_PROTECTED opt-in for evals/ did not protect")
    if fails:
        sys.stderr.write("gate-signal selftest: FAIL\n")
        for f in fails:
            sys.stderr.write(f"  - {f}\n")
        return 1
    print("gate-signal selftest: OK (denies worker writes to .harness verifier assets + the ledger + the wiring itself; "
          "segment-anchored — docs/examples/lattice.json and src/hooks/* stay writable; honors HARNESS_PROTECTED)")
    return 0


def main(argv):
    if argv and argv[0] == "selftest":
        return selftest()
    if argv and argv[0] == "check" and len(argv) > 1:
        return 1 if is_protected(argv[1]) else 0
    if argv and argv[0] == "--hook":
        try:
            data = json.load(sys.stdin)
            ti = data.get("tool_input") or data.get("toolInput") or {}
            path = ti.get("file_path") or ti.get("path") or ti.get("file")
        except Exception:
            return 0                                  # malformed input → do not block (fail-open on parse)
        if is_protected(path):
            sys.stderr.write(f"gate-signal: DENY — `{path}` is a protected verifier asset; workers are deny-on-write to it "
                             f"(anti-reward-hacking). Signals are written only by the validation path.\n")
            return 2                                   # non-zero = block the write
        return 0
    print(__doc__.split("Usage:")[1].split("Stdlib")[0].strip(), file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
