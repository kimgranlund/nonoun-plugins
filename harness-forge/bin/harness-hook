#!/usr/bin/env python3
"""harness-hook — advisory PostToolUse feedback for lattice artifacts (NEVER blocks).

Feedback injects; gates block. This is the feedback species: on a Write|Edit it surfaces two findings
about the project's `.harness/` lattice and exits 0 no matter what — it improves the loop, it does not
stop it (the blocking gate species ships separately as `gate-signal`, for the USER's own loop, where a
worker writing its own verifier is a reward-hacking surface). Mirrors the catalog's advisory-hook
discipline: `--hook` always exits 0.

Two advisories:
  1. Naming — a path created under a lattice tree (layer dirs, agents/, skills/, hooks/) is parsed against
     the typed naming grammar; a malformed name is reported (e.g. `specs/` should be `spec/`).
  2. Staleness — a write into a layer-dir cell asset reminds the operator that downstream cells may go
     stale: `lattice.py stale <cell-id> <new-hash>`.

Usage:  harness-hook --hook        (reads the PostToolUse JSON on stdin; prints advisories; exits 0)
        harness-hook selftest
Stdlib only; Python 3.8+.
"""
import json
import os
import re
import sys

_ROOT = os.environ.get("CLAUDE_PLUGIN_ROOT") or os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, os.path.join(_ROOT, "bin"))
try:
    import naming as _naming
except Exception:                                    # never let an import error block a save
    _naming = None

LAYER_DIRS = {"ontology", "spec", "rubric", "policy", "capability", "methodology", "protocol", "ledger", "pattern"}


def advise(path):
    """Return a list of advisory strings for a written path (empty = nothing to say)."""
    if not path:
        return []
    out = []
    parts = path.replace("\\", "/").split("/")
    base = parts[-1]

    # 1 — naming advisories, only for paths that look like lattice artifacts.
    if _naming is not None:
        # a directory segment that is a near-miss of a layer enum (plural drift)
        for seg in parts[:-1]:
            if seg.rstrip("s") in LAYER_DIRS and seg not in LAYER_DIRS:
                out.append(f"naming: directory `{seg}/` should mirror the layer enum exactly — `{seg.rstrip('s')}/` (directories mirror enums byte-for-byte)")
        if "agents" in parts and base.endswith(".md"):
            ok, reason = _naming.validate(base, "agent_file")
            if not ok:
                out.append(f"naming: agent file `{base}` — {reason} (grammar: {{object}}-{{actor}}.md; actors: auditor advancer distiller regenerator librarian builder scribe)")
        if "hooks" in parts and not base.endswith((".json", ".md")):
            ok, reason = _naming.validate(base, "hook_script")
            if not ok:
                out.append(f"naming: hook `{base}` — {reason} (grammar: {{gateverb}}-{{invariant}}; gateverbs: gate emit propagate)")

    # 2 — staleness reminder for a layer-dir cell asset (the segment before the file is a layer enum).
    if len(parts) >= 2 and parts[-2] in LAYER_DIRS and base.endswith((".md", ".json")):
        slug = re.sub(r"\.(md|json)$", "", base)
        out.append(f"staleness: editing a `{parts[-2]}` cell asset may stale downstream cells — `lattice.py stale {parts[-2]}.<scope>.{slug} <new-hash>` to propagate")
    return out


def _read_path_from_stdin():
    try:
        data = json.load(sys.stdin)
    except Exception:
        return None
    ti = data.get("tool_input") or data.get("toolInput") or {}
    return ti.get("file_path") or ti.get("path") or ti.get("file") or None


def selftest():
    fails = []
    def expect(cond, label):
        if not cond:
            fails.append(label)
    expect(any("spec/" in a for a in advise(".harness/specs/first.md")), "did not flag plural layer-dir drift (specs/)")
    expect(any("downstream cells may go stale" in a or "stale" in a for a in advise(".harness/spec/task-x.md")), "did not flag staleness on a layer-dir write")
    if _naming is not None:
        expect(any("agent file" in a for a in advise("agents/cell-helper.md")), "did not flag a bad actor in an agent filename")
    expect(advise("src/main.py") == [], "advised on an unrelated, non-lattice path")
    expect(advise("") == [] and advise(None) == [], "advise() not robust to empty path")
    if fails:
        sys.stderr.write("harness-hook selftest: FAIL\n")
        for f in fails:
            sys.stderr.write(f"  - {f}\n")
        return 1
    print("harness-hook selftest: OK (flags plural layer-dir drift, bad actor names, staleness on cell writes; silent on unrelated paths; robust to empty)")
    return 0


def main(argv):
    if argv and argv[0] == "selftest":
        return selftest()
    if argv and argv[0] == "--hook":
        try:
            for a in advise(_read_path_from_stdin()):
                print(f"[harness-forge] {a}")
        except Exception:
            pass                                     # advisory only — a hook crash must never block a save
        return 0                                     # ALWAYS 0
    print(__doc__.split("Usage:")[1].split("Stdlib")[0].strip(), file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
