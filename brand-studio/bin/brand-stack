#!/usr/bin/env python3
"""brand-stack — render the canonical Brand Stack one-pager (768x768 SVG) from the six tiers.

Deterministic template fill: substitutes the {PLACEHOLDER} markers in
assets/brand-stack-template.svg. The *reasoning* about what belongs in each tier is brand
judgment (the brand-methodology skill); this script only renders, so it's a bin, not a skill.

Usage:
  brand-stack --foundation "..." --strategy "..." --idea "..." \
              --identity "..." --expression "..." --output "..." [-o out.svg]
  echo '{"foundation":"...","strategy":"...","idea":"...","identity":"...","expression":"...","output":"..."}' | brand-stack -
Stdlib only (Python 3.8+).
"""
import argparse
import json
import os
import sys

PLACEHOLDERS = {
    "foundation": "{CULTURAL_FOUNDATION}",
    "strategy": "{STRATEGY}",
    "idea": "{BRAND_IDEA}",
    "identity": "{IDENTITY}",
    "expression": "{EXPRESSION}",
    "output": "{OUTPUT}",
}


def _template_path(explicit):
    if explicit:
        return explicit
    root = os.environ.get("CLAUDE_PLUGIN_ROOT")
    if root:
        cand = os.path.join(root, "assets", "brand-stack-template.svg")
        if os.path.isfile(cand):
            return cand
    here = os.path.dirname(os.path.abspath(__file__))
    return os.path.join(here, "..", "assets", "brand-stack-template.svg")


def _svg_escape(s):
    return (s.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;"))


def render(values, template_path):
    with open(template_path, encoding="utf-8") as fh:
        svg = fh.read()
    for key, marker in PLACEHOLDERS.items():
        svg = svg.replace(marker, _svg_escape(values.get(key, "")))
    return svg


def main(argv):
    ap = argparse.ArgumentParser(prog="brand-stack", description="Render the Brand Stack SVG.")
    for key in PLACEHOLDERS:
        ap.add_argument(f"--{key}", default="")
    ap.add_argument("--template", default=None)
    ap.add_argument("-o", "--out", default=None)
    ap.add_argument("stdin", nargs="?", default=None, help="pass '-' to read a JSON object of tiers from stdin")
    args = ap.parse_args(argv)

    values = {k: getattr(args, k) for k in PLACEHOLDERS}
    if args.stdin == "-":
        try:
            data = json.load(sys.stdin)
            for k in PLACEHOLDERS:
                if data.get(k):
                    values[k] = str(data[k])
        except (json.JSONDecodeError, ValueError) as e:
            print(f"brand-stack: bad JSON on stdin: {e}", file=sys.stderr)
            return 2

    tpl = _template_path(args.template)
    if not os.path.isfile(tpl):
        print(f"brand-stack: template not found: {tpl}", file=sys.stderr)
        return 2
    svg = render(values, tpl)

    if args.out:
        with open(args.out, "w", encoding="utf-8") as fh:
            fh.write(svg)
        print(f"brand-stack: wrote {args.out}")
    else:
        sys.stdout.write(svg)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
