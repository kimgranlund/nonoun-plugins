{
  "name": "dev-kit-corpus",
  "family": "corpus",
  "kernel_compat": ">=0.1.0,<0.2.0",
  "ontology": ["ontology.system.corpus-vocab"],
  "rubric_manifest": [
    { "layer": "spec", "scope": "system", "rubric_cell": "rubric.system.spec-quality" },
    { "layer": "rubric", "scope": "system", "rubric_cell": "rubric.system.rubric-quality" },
    { "layer": "pattern", "scope": "system", "rubric_cell": "rubric.system.pattern-quality" }
  ],
  "adapters": [
    {
      "kind": "validation",
      "name": "spec-quality-check",
      "target": { "layer": "spec" },
      "verifier": ["python3", "${CLAUDE_PLUGIN_ROOT}/bin/spec-quality-check.py", "{asset}"]
    },
    {
      "kind": "validation",
      "name": "rubric-calibration-check",
      "target": { "layer": "rubric" },
      "verifier": ["python3", "${CLAUDE_PLUGIN_ROOT}/bin/rubric-check.py", "{asset}"]
    },
    {
      "kind": "validation",
      "name": "pattern-quality-check",
      "target": { "layer": "pattern" },
      "verifier": ["python3", "${CLAUDE_PLUGIN_ROOT}/bin/pattern-check.py", "{asset}"]
    },
    {
      "kind": "dispatch",
      "name": "headless",
      "runtime": "headless-claude-code",
      "invocation": ["claude", "-p", "{prompt}", "--add-dir", "{worktree}", "--output-format", "stream-json"],
      "guarantees": {
        "hermetic_worktree": true,
        "gates_active": true,
        "event_stream": true,
        "stop_on": ["signal", "budget", "no-progress"]
      }
    }
  ],
  "dispatch_policy": "dispatch-policy.json",
  "seed_patterns": ["patterns/spec-decomposition.md"]
}
