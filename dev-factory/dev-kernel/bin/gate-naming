#!/usr/bin/env python3
"""gate-naming — enforce the typed naming grammar on write (the self-hosting ontology, made mechanical).

The naming system is itself the cell ontology.fleet.naming; a name that fails its grammar is a defect
caught at write time, not discovered later as drift (TDD §12). This gate validates the name of a written
artifact against `schemas/naming.schema.json`:
  - an agent card `agents/{name}.md`      must be {slug}-{actor}.md with actor in the vocab
  - a hook `hooks/{name}` / a bin gate    must be {gateverb}-{slug}
  - a layer directory                     must be a singular layer enum (spec/, never specs/)
A new vocabulary atom enters only by a ledgered `regenerating` transition on the naming cell — never an
ad-hoc coinage at a call site, which this gate denies.

Consent-wired as a PreToolUse(Write|Edit) hook in the worker loop; non-zero exit = DENY.

Usage:  gate-naming --hook | check <path> | selftest
Stdlib only; Python 3.8+.
"""
import json
import os
import re
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import _gates  # noqa: E402

_ROOT = os.environ.get("CLAUDE_PLUGIN_ROOT") or os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
_SLUG = re.compile(r"^[a-z0-9]+(?:-[a-z0-9]+)*$")


def _vocab():
    schema = json.load(open(os.path.join(_ROOT, "schemas", "naming.schema.json"), encoding="utf-8"))
    return schema.get("vocab", {})


def name_violation(path, vocab=None):
    """Return a reason string if `path`'s name breaks the grammar, else None."""
    if not path:
        return None
    vocab = vocab or _vocab()
    p = path.replace("\\", "/")
    parts = p.split("/")
    base = parts[-1]

    # agent card: {slug}-{actor}.md
    if "/agents/" in p and base.endswith(".md") and not base.startswith("critic-") and base != "README.md":
        stem = base[:-3]
        actors = vocab.get("actor", [])
        if "-" not in stem or stem.rsplit("-", 1)[1] not in actors:
            return f"agent file '{base}' must be {{slug}}-{{actor}}.md with actor in {actors}"
        if not _SLUG.match(stem):
            return f"agent file '{base}' is not kebab-case"

    # hook / gate script: {gateverb}-{slug}
    if ("/hooks/" in p or "/bin/" in p) and (base.startswith(("gate-", "emit-", "propagate-"))):
        gateverbs = vocab.get("gateverb", [])
        head = base.split("-", 1)[0]
        if head not in gateverbs:
            return f"hook '{base}' must start with a gateverb {gateverbs}"

    # layer directory must be a singular layer enum
    layers = vocab.get("layer", [])
    for seg in parts[:-1]:
        if seg.endswith("s") and seg[:-1] in layers:
            return f"layer directory '{seg}/' must be singular '{seg[:-1]}/' (directories mirror enums byte-for-byte)"
    return None


def selftest():
    fails = []
    v = {"actor": ["advancer", "triager", "architect", "validator"], "gateverb": ["gate", "emit", "propagate"],
         "layer": ["spec", "rubric", "policy"]}
    def expect(c, m):
        if not c:
            fails.append(m)
    expect(name_violation("dev-kernel/agents/cell-advancer.md", v) is None, "rejected a valid agent name")
    expect(name_violation("dev-kernel/agents/cellAdvancer.md", v) is not None, "accepted a non-{slug}-{actor} agent name")
    expect(name_violation("dev-kernel/agents/cell-frobnicator.md", v) is not None, "accepted an unknown actor")
    expect(name_violation("dev-kernel/agents/critic-reward-hacking.md", v) is None, "rejected a critic-* card")
    expect(name_violation("x/bin/gate-signal", v) is None, "rejected a valid gateverb hook")
    expect(name_violation("x/bin/check-signal", v) is None, "flagged a non-gate bin (only gateverb-prefixed are checked)")
    expect(name_violation(".agents/dev-factory/specs/x.md", v) is not None, "accepted a pluralized layer dir 'specs/'")
    expect(name_violation(".agents/dev-factory/spec/x.md", v) is None, "flagged the correct singular 'spec/'")
    if fails:
        sys.stderr.write("gate-naming selftest: FAIL\n")
        for f in fails:
            sys.stderr.write(f"  - {f}\n")
        return 1
    print("gate-naming selftest: OK ({slug}-{actor} agent cards, gateverb hooks, singular layer dirs; "
          "critic-* exempt; unknown actors and pluralized layer dirs denied)")
    return 0


def main(argv):
    if argv and argv[0] == "selftest":
        return selftest()
    if argv and argv[0] == "--hook":
        tool, path, _cmd = _gates.read_payload()
        if tool is None:                       # unparseable payload — fail CLOSED, never open
            return _gates.deny("gate-naming: DENIED — unparseable PreToolUse payload; failing closed.")
        if tool in ("Write", "Edit", "MultiEdit", "NotebookEdit"):
            why = name_violation(path)
            if why:
                return _gates.deny(f"gate-naming: DENIED — {why}")
        return 0
    if argv and argv[0] == "check":
        why = name_violation(argv[1] if len(argv) > 1 else "")
        if why:
            sys.stderr.write(why + "\n")
            return 1
        return 0
    sys.stderr.write("usage: gate-naming --hook | check <path> | selftest\n")
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
