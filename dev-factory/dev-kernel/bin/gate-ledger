#!/usr/bin/env python3
"""gate-ledger — the append-only audit guard.

The ledger is the source of truth for every state transition (harness-and-storage.md); it is APPEND-only.
A Write/Edit/rm against an existing ledger file (or the coordination index slice) is denied — entries are
added only through the emit path (a subprocess append), never rewritten. Without this, a worker could
launder a false transition by editing history; provenance that can be retrofitted is not provenance.

Consent-wired as a PreToolUse(Write|Edit) hook in the worker loop; non-zero exit = DENY.

Usage:  gate-ledger --hook | check <path> | selftest
Stdlib only; Python 3.8+.
"""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import _gates  # noqa: E402

if __name__ == "__main__":
    sys.exit(_gates.run_path_gate("gate-ledger", _gates.LEDGER, sys.argv[1:], "append-only ledger"))
