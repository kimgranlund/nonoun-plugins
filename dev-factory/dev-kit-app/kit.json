{
  "name": "dev-kit-app",
  "family": "app",
  "kernel_compat": ">=0.1.0,<0.2.0",
  "ontology": ["ontology.system.app-vocab"],
  "rubric_manifest": [
    { "layer": "capability", "scope": "system", "rubric_cell": "rubric.system.test-suite" },
    { "layer": "protocol", "scope": "workflow", "rubric_cell": "rubric.workflow.contract-tests" }
  ],
  "authoring": [
    { "layer": "capability", "mode": "multi-file", "layout": "{layer}/{slug}/",
      "note": "A capability is real multi-file source authored to a directory, graded by its per-cell verify.mjs critic harness (worker-deny). Logic in pure ES modules the harness imports headlessly; rendering in a thin shell." }
  ],
  "adapters": [
    {
      "kind": "validation",
      "name": "capability-harness",
      "target": { "layer": "capability" },
      "verifier": ["node", "{asset}/verify.mjs"]
    },
    {
      "kind": "validation",
      "name": "spec-contract",
      "target": { "layer": "spec" },
      "verifier": ["python3", "-c", "import sys; t=open(sys.argv[1], encoding='utf-8').read(); sys.exit(0 if ('acceptance_criteria' in t and 'non_goals' in t) else 1)", "{asset}"]
    },
    {
      "kind": "validation",
      "name": "contract-tests",
      "target": { "layer": "protocol" },
      "verifier": ["python3", "${CLAUDE_PLUGIN_ROOT}/bin/test-suite-check.py", "contract", "{asset}"]
    },
    {
      "kind": "dispatch",
      "name": "headless",
      "runtime": "headless-claude-code",
      "invocation": ["claude", "-p", "{prompt}", "--add-dir", "{worktree}", "--output-format", "stream-json"],
      "guarantees": {
        "hermetic_worktree": true,
        "gates_active": true,
        "event_stream": true,
        "stop_on": ["signal", "budget", "no-progress"]
      }
    }
  ],
  "dispatch_policy": "dispatch-policy.json"
}
