{
  "family": "app",
  "rules": [
    {
      "match": { "ticket_type": ["bug"] },
      "plan": {
        "orchestration_shape": "single-pass",
        "loop_strategy": "bisect",
        "context_plan": { "retrieval": "minimal", "compaction": "never", "working_set_only": true },
        "effort": { "model_tier": "mid", "reasoning_effort": "high", "max_iterations": 6, "parallelism": 1 },
        "delegation": { "mode": "none", "max_depth": 0 }
      }
    },
    {
      "match": { "target_layer": ["capability"] },
      "plan": {
        "orchestration_shape": "orchestrator-workers",
        "loop_strategy": "tracer-bullet",
        "context_plan": { "retrieval": "spec-rubric-patterns", "compaction": "never", "working_set_only": true },
        "effort": { "model_tier": "mid", "reasoning_effort": "moderate", "max_iterations": 6, "parallelism": 2 },
        "delegation": { "mode": "team", "max_depth": 2 }
      }
    }
  ],
  "default": {
    "orchestration_shape": "single-pass",
    "loop_strategy": "single",
    "context_plan": { "retrieval": "minimal", "compaction": "never", "working_set_only": true },
    "effort": { "model_tier": "small", "reasoning_effort": "low", "max_iterations": 3, "parallelism": 1 },
    "delegation": { "mode": "none", "max_depth": 0 }
  }
}
