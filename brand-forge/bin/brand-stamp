#!/usr/bin/env python3
"""brand-stamp — stamp a finished brand corpus into a distributable artifact.

Two forms, chosen by destination (see skills/brand-corpus/references/stamping.md):
  docs    the flat-convention corpus + a thin skill — for Claude chat / Projects (knowledge, no MCP)
  plugin  the corpus + the brand-corpus MCP + a thin skill, as an installable plugin — Claude Code / Cowork

Usage:
  brand-stamp docs   <corpus_dir> --name <brand> -o <out_dir>
  brand-stamp plugin <corpus_dir> --name <brand> -o <out_dir> [--linked]
      --linked  point the MCP at a live corpus dir (userConfig.corpus_dir) instead of bundling a snapshot

Mechanical scaffolding only — readiness/quality judgment lives in /brand-stamp + the brand-corpus
skill. Stdlib only (Python 3.8+). The plugin form is built to pass plugins-factory's validate_plugin.py.
"""
import argparse
import json
import os
import re
import shutil
import sys

LAYER_DIR = re.compile(r"^\d\d-[a-z][a-z0-9-]*$")            # 01-foundation
FLAT_DOC = re.compile(r"^(\d\d-[a-z][a-z0-9-]*)--(.+)\.md$")  # 01-foundation--the-position.md
KEBAB = re.compile(r"[^a-z0-9]+")


def _kebab(s):
    return KEBAB.sub("-", s.strip().lower()).strip("-")


def read_corpus(corpus):
    """Return (docs, extras): docs = [(layer, name, text)] from either convention; extras = [(rel, abs)]
    for token files to carry verbatim."""
    if not os.path.isdir(corpus):
        sys.exit(f"brand-stamp: corpus dir not found: {corpus}")
    docs, extras = [], []
    for entry in sorted(os.listdir(corpus)):
        full = os.path.join(corpus, entry)
        if os.path.isdir(full) and LAYER_DIR.match(entry):            # folder convention
            for f in sorted(os.listdir(full)):
                if f.endswith(".md"):
                    docs.append((entry, f[:-3], open(os.path.join(full, f), encoding="utf-8").read()))
        elif os.path.isfile(full):
            m = FLAT_DOC.match(entry)                                 # flat convention
            if m:
                docs.append((m.group(1), m.group(2), open(full, encoding="utf-8").read()))
            elif "token" in entry.lower() and entry.lower().endswith((".json", ".css")):
                extras.append((entry, full))
    if not docs:
        sys.exit(f"brand-stamp: no brand-corpus documents found in {corpus} "
                 f"(expected NN-layer/ dirs or NN-layer--name.md files)")
    return docs, extras


def _thin_skill(brand, docs, has_mcp):
    name = f"{_kebab(brand)}-brand"
    layers = ", ".join(sorted({l for l, _, _ in docs})) or "(none yet)"
    retrieval = (
        "Query the bundled `brand-corpus` MCP (`list_brand_documents` / `search_brand` / "
        "`fetch_brand_section` / `outline_brand_document` / `get_brand_tokens`) to read the live documents."
        if has_mcp else
        "The brand's documents are attached as project knowledge — read them directly, by layer."
    )
    return (
        f"---\nname: {name}\ndescription: >\n"
        f"  The {brand} brand — its cultural foundation, positioning, identity, voice, and tokens. Use when\n"
        f"  working on, referencing, or extending the {brand} brand: its position, point of view, voice, or guidelines.\n"
        f"---\n\n"
        f"# {brand} — brand\n\n"
        f"This skill carries the **{brand}** brand corpus — the layered foundation → expression → stewardship\n"
        f"documents. {retrieval}\n\n"
        f"**Layers present:** {layers}\n\n"
        f"The corpus follows the canonical brand layers (01-foundation … 08-evaluation). **01-foundation is\n"
        f"load-bearing** — everything else descends from it; don't contradict it. When the brand evolves, record\n"
        f"the change in 08-evaluation rather than silently overwriting a decision.\n"
    )


def emit_docs(corpus, out, brand):
    docs, extras = read_corpus(corpus)
    os.makedirs(out, exist_ok=True)
    for layer, nm, text in docs:                                      # flat-convention knowledge docs
        open(os.path.join(out, f"{layer}--{nm}.md"), "w", encoding="utf-8").write(text)
    for rel, src in extras:
        shutil.copy2(src, os.path.join(out, rel))
    open(os.path.join(out, "SKILL.md"), "w", encoding="utf-8").write(_thin_skill(brand, docs, has_mcp=False))
    return len(docs), len(extras)


def emit_plugin(corpus, out, brand, linked):
    name = f"{_kebab(brand)}-brand"
    root = os.path.join(out, name)
    docs, extras = read_corpus(corpus)
    os.makedirs(os.path.join(root, ".claude-plugin"), exist_ok=True)
    os.makedirs(os.path.join(root, "bin"), exist_ok=True)
    os.makedirs(os.path.join(root, "skills", name), exist_ok=True)

    ref_mcp = os.path.join(os.path.dirname(os.path.abspath(__file__)), "brand-corpus-mcp.py")
    dst_mcp = os.path.join(root, "bin", "brand-corpus-mcp.py")
    shutil.copy2(ref_mcp, dst_mcp)                                    # co-locate the reference MCP server
    os.chmod(dst_mcp, 0o755)

    if linked:
        corpus_env = "${user_config.corpus_dir}"
    else:
        cdir = os.path.join(root, "corpus")                          # bundle a folder-convention snapshot
        for layer, nm, text in docs:
            os.makedirs(os.path.join(cdir, layer), exist_ok=True)
            open(os.path.join(cdir, layer, f"{nm}.md"), "w", encoding="utf-8").write(text)
        for rel, src in extras:
            shutil.copy2(src, os.path.join(cdir, rel))
        corpus_env = "${CLAUDE_PLUGIN_ROOT}/corpus"

    pj = {
        "name": name,
        "version": "0.1.0",
        "description": (f"The {brand} brand corpus — foundation, positioning, identity, voice, tokens — "
                        f"with a read-only brand-corpus MCP for retrieval."),
        "keywords": ["brand", _kebab(brand), "brand-corpus", "design"],
    }
    if linked:
        pj["userConfig"] = {"corpus_dir": {
            "type": "directory",
            "description": f"Path to the {brand} brand corpus directory.",
            "sensitive": False}}
    _write_json(os.path.join(root, ".claude-plugin", "plugin.json"), pj)

    mcp = {"mcpServers": {"brand-corpus": {
        "command": "python3",
        "args": ["${CLAUDE_PLUGIN_ROOT}/bin/brand-corpus-mcp.py"],
        "env": {"BRAND_CORPUS_DIR": corpus_env}}}}
    _write_json(os.path.join(root, ".mcp.json"), mcp)

    open(os.path.join(root, "skills", name, "SKILL.md"), "w", encoding="utf-8").write(
        _thin_skill(brand, docs, has_mcp=True))
    return root, len(docs)


def _write_json(path, obj):
    open(path, "w", encoding="utf-8").write(json.dumps(obj, indent=2) + "\n")


def main(argv):
    ap = argparse.ArgumentParser(prog="brand-stamp", description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = ap.add_subparsers(dest="form", required=True)
    for form in ("docs", "plugin"):
        p = sub.add_parser(form)
        p.add_argument("corpus")
        p.add_argument("--name", required=True)
        p.add_argument("-o", "--out", required=True)
        if form == "plugin":
            p.add_argument("--linked", action="store_true",
                           help="point the MCP at a live corpus_dir via userConfig instead of bundling a snapshot")
    args = ap.parse_args(argv)

    if args.form == "docs":
        n, e = emit_docs(args.corpus, args.out, args.name)
        print(f"brand-stamp: wrote {n} flat knowledge doc(s) + {e} token file(s) + SKILL.md to {args.out}")
        print("  → upload the NN-layer--*.md as Claude Project knowledge; use SKILL.md as the brand skill.")
    else:
        root, n = emit_plugin(args.corpus, args.out, args.name, args.linked)
        kind = "linked" if args.linked else "bundled"
        print(f"brand-stamp: scaffolded plugin at {root} ({n} doc(s), {kind} corpus)")
        print(f"  → validate:  python3 <plugins-factory>/bin/validate_plugin.py plugin {root}")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
